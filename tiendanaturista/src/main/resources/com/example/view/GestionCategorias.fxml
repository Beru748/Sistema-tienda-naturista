<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.Separator?>
<?import javafx.geometry.Insets?>

<VBox
    spacing="15.0"
    prefWidth="520.0"
    prefHeight="400.0"
    style="-fx-background-color: #FCFAF7;"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets top="15.0" right="15.0" bottom="15.0" left="15.0" />
    </padding>
    <children>

        <!-- ── Encabezado ── -->
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <Label text="🏷️"
                       style="-fx-font-size: 18px;" />
                <Label text="Gestión de Categorías"
                       style="-fx-font-family: 'Georgia';
                              -fx-font-size: 18px;
                              -fx-font-style: italic;
                              -fx-text-fill: #2d4a28;" />
            </children>
        </HBox>

        <Separator style="-fx-background-color: #E0EDD9;" />

        <!-- ── Tabla central ── -->
        <TableView
            fx:id="tablaCategorias"
            VBox.vgrow="ALWAYS"
            style="-fx-background-color: #FFFFFF;
                   -fx-border-color: #E0EDD9;
                   -fx-border-radius: 8;
                   -fx-background-radius: 8;
                   -fx-table-cell-border-color: #F5F0EA;">
            <columns>

                <TableColumn
                    fx:id="colCatId"
                    text="ID"
                    prefWidth="55.0"
                    style="-fx-alignment: CENTER;" />

                <TableColumn
                    fx:id="colCatNombre"
                    text="Nombre"
                    prefWidth="160.0"
                    style="-fx-alignment: CENTER_LEFT;" />

                <TableColumn
                    fx:id="colCatDescripcion"
                    text="Descripción"
                    prefWidth="265.0"
                    style="-fx-alignment: CENTER_LEFT;" />

            </columns>
            <placeholder>
                <StackPane>
                    <children>
                        <Label text="Sin categorías registradas"
                               style="-fx-font-family: 'Georgia';
                                      -fx-font-style: italic;
                                      -fx-font-size: 13px;
                                      -fx-text-fill: #B8C8B0;" />
                    </children>
                </StackPane>
            </placeholder>
        </TableView>

        <Separator style="-fx-background-color: #E0EDD9;" />

        <!-- ── Formulario de ingreso ── -->
        <HBox spacing="8.0" alignment="CENTER_LEFT">
            <children>

                <TextField
                    fx:id="campoNombreCategoria"
                    promptText="Nombre..."
                    prefWidth="150.0"
                    prefHeight="34.0"
                    style="-fx-background-color: #FFFFFF;
                           -fx-border-color: #D4E8CC;
                           -fx-border-radius: 7;
                           -fx-background-radius: 7;
                           -fx-font-family: 'Arial';
                           -fx-font-size: 12px;
                           -fx-padding: 0 10 0 10;" />

                <TextField
                    fx:id="campoDescripcionCategoria"
                    promptText="Descripción..."
                    prefHeight="34.0"
                    prefWidth="200.0"
                    HBox.hgrow="ALWAYS"
                    style="-fx-background-color: #FFFFFF;
                           -fx-border-color: #D4E8CC;
                           -fx-border-radius: 7;
                           -fx-background-radius: 7;
                           -fx-font-family: 'Arial';
                           -fx-font-size: 12px;
                           -fx-padding: 0 10 0 10;" />

                <Button
                    fx:id="btnAnadirCategoria"
                    text="＋  Añadir"
                    prefHeight="34.0"
                    mnemonicParsing="false"
                    style="-fx-background-color: #0CC053;
                           -fx-text-fill: #FFFFFF;
                           -fx-font-family: 'Arial';
                           -fx-font-size: 12px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 7;
                           -fx-cursor: hand;
                           -fx-padding: 0 14 0 14;" />

            </children>
        </HBox>

        <!-- ── Botón eliminar (alineado a la derecha) ── -->
        <HBox alignment="CENTER_RIGHT">
            <children>
                <Button
                    fx:id="btnEliminarCategoria"
                    text="🗑  Eliminar seleccionado"
                    prefHeight="32.0"
                    mnemonicParsing="false"
                    style="-fx-background-color: #FFF0ED;
                           -fx-text-fill: #C0392B;
                           -fx-font-family: 'Arial';
                           -fx-font-size: 12px;
                           -fx-border-color: #F5C6C1;
                           -fx-border-radius: 7;
                           -fx-background-radius: 7;
                           -fx-cursor: hand;
                           -fx-padding: 0 14 0 14;" />
            </children>
        </HBox>

    </children>
</VBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="400.0" prefWidth="520.0" spacing="15.0" style="-fx-background-color: #FCFAF7;" stylesheets="@../css/style__menu.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>
    <children>

        <!-- ── Encabezado ── -->
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <Label style="-fx-font-size: 18px;" text="🏷️" />
                <Label style="-fx-font-family: 'Georgia';                               -fx-font-size: 18px;                               -fx-font-style: italic;                               -fx-text-fill: #2d4a28;" text="Gestión de Categorías" />
            </children>
        </HBox>

        <Separator style="-fx-background-color: #E0EDD9;" />

        <!-- ── Tabla central ── -->
        <TableView fx:id="tablaCategorias" style="-fx-background-color: #FFFFFF;                    -fx-border-color: #E0EDD9;                    -fx-border-radius: 8;                    -fx-background-radius: 8;                    -fx-table-cell-border-color: #F5F0EA;" VBox.vgrow="ALWAYS">
            <columns>

                <TableColumn fx:id="colCatId" prefWidth="55.0" style="-fx-alignment: CENTER;" text="ID" />

                <TableColumn fx:id="colCatNombre" prefWidth="160.0" style="-fx-alignment: CENTER_LEFT;" text="Nombre" />

                <TableColumn fx:id="colCatDescripcion" prefWidth="265.0" style="-fx-alignment: CENTER_LEFT;" text="Descripción" />

            </columns>
            <placeholder>
                <StackPane>
                    <children>
                        <Label style="-fx-font-family: 'Georgia';                                       -fx-font-style: italic;                                       -fx-font-size: 13px;                                       -fx-text-fill: #B8C8B0;" text="Sin categorías registradas" />
                    </children>
                </StackPane>
            </placeholder>
        </TableView>

        <Separator style="-fx-background-color: #E0EDD9;" />

        <!-- ── Formulario de ingreso ── -->
        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <children>

                <TextField fx:id="campoNombreCategoria" prefHeight="34.0" prefWidth="150.0" promptText="Nombre..." style="-fx-background-color: #FFFFFF;                            -fx-border-color: #D4E8CC;                            -fx-border-radius: 7;                            -fx-background-radius: 7;                            -fx-font-family: 'Arial';                            -fx-font-size: 12px;                            -fx-padding: 0 10 0 10;" />

                <TextField fx:id="campoDescripcionCategoria" prefHeight="34.0" prefWidth="200.0" promptText="Descripción..." style="-fx-background-color: #FFFFFF;                            -fx-border-color: #D4E8CC;                            -fx-border-radius: 7;                            -fx-background-radius: 7;                            -fx-font-family: 'Arial';                            -fx-font-size: 12px;                            -fx-padding: 0 10 0 10;" HBox.hgrow="ALWAYS" />

                <Button fx:id="btnAnadirCategoria" mnemonicParsing="false" prefHeight="34.0" style="-fx-background-color: #0CC053;                            -fx-text-fill: #FFFFFF;                            -fx-font-family: 'Arial';                            -fx-font-size: 12px;                            -fx-font-weight: bold;                            -fx-background-radius: 7;                            -fx-cursor: hand;                            -fx-padding: 0 14 0 14;" text="＋  Añadir" />

            </children>
        </HBox>

        <!-- ── Botón eliminar (alineado a la derecha) ── -->
        <HBox alignment="CENTER_RIGHT">
            <children>
                <Button fx:id="btnEliminarCategoria" mnemonicParsing="false" prefHeight="32.0" style="-fx-background-color: #FFF0ED;                            -fx-text-fill: #C0392B;                            -fx-font-family: 'Arial';                            -fx-font-size: 12px;                            -fx-border-color: #F5C6C1;                            -fx-border-radius: 7;                            -fx-background-radius: 7;                            -fx-cursor: hand;                            -fx-padding: 0 14 0 14;" text="🗑  Eliminar seleccionado" />
            </children>
        </HBox>

    </children>
</VBox>

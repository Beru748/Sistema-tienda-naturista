<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Separator?>
<?import javafx.geometry.Insets?>
<?import javafx.geometry.HPos?>

<VBox
    spacing="15.0"
    prefWidth="520.0"
    style="-fx-background-color: #FCFAF7;"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controller.InventarioController">
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
    </padding>
    <children>


        <!--  CABECERA  -->

        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <Label text="🌿"
                       style="-fx-font-size: 20px;" />
                <Label text="Datos del Producto"
                       style="-fx-font-family: 'Georgia';
                              -fx-font-size: 22px;
                              -fx-font-style: italic;
                              -fx-text-fill: #2d4a28;" />
            </children>
        </HBox>

        <Separator style="-fx-background-color: #E0EDD9;" />


        <!--  CUERPO  GridPane de campos     -->
        <GridPane hgap="15.0" vgap="15.0" alignment="CENTER">
            <columnConstraints>
                <!-- Columna 0: Labels -->
                <ColumnConstraints
                    minWidth="145.0"
                    halignment="RIGHT" />
                <!-- Columna 1: Controles -->
                <ColumnConstraints
                    minWidth="280.0"
                    hgrow="ALWAYS" />
            </columnConstraints>
            <children>

                <!-- Fila 0: Código de Barras -->
                <Label text="Código de Barras:"
                       GridPane.columnIndex="0" GridPane.rowIndex="0"
                       style="-fx-font-family: 'Arial';
                              -fx-font-size: 13px;
                              -fx-text-fill: #2d4a28;" />
                <TextField
                    fx:id="txtCodigoBarras"
                    GridPane.columnIndex="1" GridPane.rowIndex="0"
                    prefHeight="34.0"
                    maxWidth="Infinity"
                    style="-fx-background-color: #FFFFFF;
                           -fx-border-color: #D4E8CC;
                           -fx-border-radius: 7;
                           -fx-background-radius: 7;
                           -fx-font-family: 'Arial';
                           -fx-font-size: 13px;
                           -fx-padding: 0 10 0 10;" />

                <!-- Fila 1: Nombre -->
                <Label text="Nombre:"
                       GridPane.columnIndex="0" GridPane.rowIndex="1"
                       style="-fx-font-family: 'Arial';
                              -fx-font-size: 13px;
                              -fx-text-fill: #2d4a28;" />
                <TextField
                    fx:id="txtNombre"
                    GridPane.columnIndex="1" GridPane.rowIndex="1"
                    prefHeight="34.0"
                    maxWidth="Infinity"
                    style="-fx-background-color: #FFFFFF;
                           -fx-border-color: #D4E8CC;
                           -fx-border-radius: 7;
                           -fx-background-radius: 7;
                           -fx-font-family: 'Arial';
                           -fx-font-size: 13px;
                           -fx-padding: 0 10 0 10;" />

                <!-- Fila 2: Descripción -->
                <Label text="Descripción:"
                       GridPane.columnIndex="0" GridPane.rowIndex="2"
                       style="-fx-font-family: 'Arial';
                              -fx-font-size: 13px;
                              -fx-text-fill: #2d4a28;" />
                <TextArea
                    fx:id="txtDescripcion"
                    GridPane.columnIndex="1" GridPane.rowIndex="2"
                    prefHeight="60.0"
                    maxWidth="Infinity"
                    wrapText="true"
                    style="-fx-background-color: #FFFFFF;
                           -fx-border-color: #D4E8CC;
                           -fx-border-radius: 7;
                           -fx-background-radius: 7;
                           -fx-font-family: 'Arial';
                           -fx-font-size: 13px;" />

                <!-- Fila 3: Precio -->
                <Label text="Precio:"
                       GridPane.columnIndex="0" GridPane.rowIndex="3"
                       style="-fx-font-family: 'Arial';
                              -fx-font-size: 13px;
                              -fx-text-fill: #2d4a28;" />
                <TextField
                    fx:id="txtPrecio"
                    GridPane.columnIndex="1" GridPane.rowIndex="3"
                    prefHeight="34.0"
                    maxWidth="Infinity"
                    promptText="Ej: 15000"
                    style="-fx-background-color: #FFFFFF;
                           -fx-border-color: #D4E8CC;
                           -fx-border-radius: 7;
                           -fx-background-radius: 7;
                           -fx-font-family: 'Arial';
                           -fx-font-size: 13px;
                           -fx-padding: 0 10 0 10;" />

                <!-- Fila 4: Stock -->
                <Label text="Stock:"
                       GridPane.columnIndex="0" GridPane.rowIndex="4"
                       style="-fx-font-family: 'Arial';
                              -fx-font-size: 13px;
                              -fx-text-fill: #2d4a28;" />
                <TextField
                    fx:id="txtStock"
                    GridPane.columnIndex="1" GridPane.rowIndex="4"
                    prefHeight="34.0"
                    maxWidth="Infinity"
                    promptText="Ej: 50"
                    style="-fx-background-color: #FFFFFF;
                           -fx-border-color: #D4E8CC;
                           -fx-border-radius: 7;
                           -fx-background-radius: 7;
                           -fx-font-family: 'Arial';
                           -fx-font-size: 13px;
                           -fx-padding: 0 10 0 10;" />

                <!-- Fila 5: Unidad de Medida -->
                <Label text="Unidad de Medida:"
                       GridPane.columnIndex="0" GridPane.rowIndex="5"
                       style="-fx-font-family: 'Arial';
                              -fx-font-size: 13px;
                              -fx-text-fill: #2d4a28;" />
                <ComboBox
                    fx:id="comboUnidadMedida"
                    GridPane.columnIndex="1" GridPane.rowIndex="5"
                    prefHeight="34.0"
                    maxWidth="Infinity"
                    promptText="Ej: Unidad, Frasco..."
                    style="-fx-background-color: #FFFFFF;
                           -fx-border-color: #D4E8CC;
                           -fx-border-radius: 7;
                           -fx-background-radius: 7;
                           -fx-font-family: 'Arial';
                           -fx-font-size: 13px;" />

                <!-- Fila 6: Fecha Vencimiento -->
                <Label text="Fecha Vencimiento:"
                       GridPane.columnIndex="0" GridPane.rowIndex="6"
                       style="-fx-font-family: 'Arial';
                              -fx-font-size: 13px;
                              -fx-text-fill: #2d4a28;" />
                <DatePicker
                    fx:id="dateVencimiento"
                    GridPane.columnIndex="1" GridPane.rowIndex="6"
                    prefHeight="34.0"
                    maxWidth="Infinity"
                    style="-fx-background-color: #FFFFFF;
                           -fx-border-color: #D4E8CC;
                           -fx-border-radius: 7;
                           -fx-background-radius: 7;
                           -fx-font-family: 'Arial';
                           -fx-font-size: 13px;" />

                <!-- Fila 7: Categoría -->
                <Label text="Categoría:"
                       GridPane.columnIndex="0" GridPane.rowIndex="7"
                       style="-fx-font-family: 'Arial';
                              -fx-font-size: 13px;
                              -fx-text-fill: #2d4a28;" />
                <ComboBox
                    fx:id="comboCategoriaForm"
                    GridPane.columnIndex="1" GridPane.rowIndex="7"
                    prefHeight="34.0"
                    maxWidth="Infinity"
                    promptText="Seleccionar categoría..."
                    style="-fx-background-color: #FFFFFF;
                           -fx-border-color: #D4E8CC;
                           -fx-border-radius: 7;
                           -fx-background-radius: 7;
                           -fx-font-family: 'Arial';
                           -fx-font-size: 13px;" />

                <!-- Fila 8: Laboratorio -->
                <Label text="Laboratorio:"
                       GridPane.columnIndex="0" GridPane.rowIndex="8"
                       style="-fx-font-family: 'Arial';
                              -fx-font-size: 13px;
                              -fx-text-fill: #2d4a28;" />
                <ComboBox
                    fx:id="comboLaboratorioForm"
                    GridPane.columnIndex="1" GridPane.rowIndex="8"
                    prefHeight="34.0"
                    maxWidth="Infinity"
                    promptText="Seleccionar laboratorio..."
                    style="-fx-background-color: #FFFFFF;
                           -fx-border-color: #D4E8CC;
                           -fx-border-radius: 7;
                           -fx-background-radius: 7;
                           -fx-font-family: 'Arial';
                           -fx-font-size: 13px;" />

            </children>
        </GridPane>

        <!-- Separador antes de los botones -->
        <Separator style="-fx-background-color: #E0EDD9;" />

        <!--  PIE DE PÁGINA — Botones                    -->
        <HBox alignment="CENTER_RIGHT" spacing="15.0">
            <children>

                <!-- Botón Cancelar -->
                <Button
                    fx:id="btnCancelarForm"
                    text="Cancelar"
                    prefHeight="36.0"
                    prefWidth="100.0"
                    mnemonicParsing="false"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #4a6e42;
                           -fx-font-family: 'Arial';
                           -fx-font-size: 13px;
                           -fx-border-color: #C8E6C0;
                           -fx-border-radius: 7;
                           -fx-background-radius: 7;
                           -fx-cursor: hand;" />

                <!-- Botón Guardar -->
                <Button
                    fx:id="btnGuardarForm"
                    text="✔  Guardar Producto"
                    prefHeight="36.0"
                    mnemonicParsing="false"
                    style="-fx-background-color: #0CC053;
                           -fx-text-fill: #FFFFFF;
                           -fx-font-family: 'Arial';
                           -fx-font-size: 13px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 7;
                           -fx-cursor: hand;
                           -fx-padding: 0 20 0 20;" />

            </children>
        </HBox>

    </children>
</VBox>

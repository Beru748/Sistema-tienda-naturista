<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15.0" style="-fx-background-color: transparent;" stylesheets="@../css/style__menu.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controller.InventarioController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>

        <!--  ENCABEZADO                                 -->
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <Label style="-fx-font-size: 20px;" text="📦" />
                <VBox spacing="1.0">
                    <children>
                        <Label style="-fx-font-family: 'Georgia';                                     -fx-font-size: 20px;                                     -fx-font-style: italic;                                     -fx-text-fill: #2d4a28;" text="Inventario" />
                        <Label style="-fx-font-family: 'Arial';                                     -fx-font-size: 10.5px;                                     -fx-text-fill: #A8B8A0;" text="Gestión de productos y existencias" />
                    </children>
                </VBox>
            </children>
        </HBox>

        <Separator style="-fx-background-color: #E0EDD9;" />

        <!--  SECCIÓN SUPERIOR — Filtros                 -->
        <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #FFFFFF;                     -fx-background-radius: 10;                     -fx-border-color: #E0EDD9;                     -fx-border-radius: 10;                     -fx-border-width: 1;">
            <padding>
                <Insets bottom="12.0" left="16.0" right="16.0" top="12.0" />
            </padding>
            <children>

                <Label style="-fx-font-size: 14px; -fx-text-fill: #A8B8A0;" text="🔍" />

                <!-- Campo de búsqueda -->
                <TextField fx:id="campoBusqueda" prefHeight="36.0" prefWidth="220.0" promptText="Buscar producto..." styleClass="campo-filtro" />

                <Separator orientation="VERTICAL" prefHeight="24.0" style="-fx-background-color: #E0EDD9;" />

                <!-- ComboBox Categoría -->
                <ComboBox fx:id="comboCategoria" prefHeight="36.0" prefWidth="150.0" promptText="Categoría" styleClass="combo-filtro" />

                <!-- ComboBox Laboratorio -->
                <ComboBox fx:id="comboLaboratorio" prefHeight="36.0" prefWidth="150.0" promptText="Laboratorio" styleClass="combo-filtro" />

                <!-- Spacer -->
                <Pane HBox.hgrow="ALWAYS" />

                <!-- Botón limpiar -->
                <Button fx:id="btnLimpiarFiltros" mnemonicParsing="false" prefHeight="36.0" styleClass="boton-secundario" text="↺  Limpiar Filtros" />

            </children>
        </HBox>

        <!--  SECCIÓN CENTRAL — Tabla de inventario      -->
        <TableView fx:id="tablaInventario" style="-fx-background-color: #FFFFFF;                 -fx-border-color: #E0EDD9;                 -fx-border-radius: 10;                 -fx-background-radius: 10;                 -fx-table-cell-border-color: #F5F0EA;" VBox.vgrow="ALWAYS">
            <columns>

                <TableColumn fx:id="colId" prefWidth="60.0" styleClass="col-centrada" text="ID" />

                <TableColumn fx:id="colNombre" prefWidth="210.0" styleClass="col-izquierda" text="Nombre" />

                <TableColumn fx:id="colCategoria" prefWidth="130.0" styleClass="col-izquierda" text="Categoría" />

                <TableColumn fx:id="colLaboratorio" prefWidth="140.0" styleClass="col-izquierda" text="Laboratorio" />

                <TableColumn fx:id="colStock" prefWidth="80.0" styleClass="col-centrada" text="Stock" />

                <TableColumn fx:id="colPrecio" prefWidth="100.0" styleClass="col-derecha" text="Precio" />

                <TableColumn fx:id="colVencimiento" prefWidth="120.0" styleClass="col-centrada" text="Vencimiento" />

            </columns>
            <placeholder>
                <StackPane>
                    <children>
                        <VBox alignment="CENTER" spacing="10.0">
                            <children>
                                <Label style="-fx-font-size: 36px;" text="🌿" />
                                <Label style="-fx-font-family: 'Georgia';                                             -fx-font-size: 14px;                                             -fx-font-style: italic;                                             -fx-text-fill: #B8C8B0;" text="No se encontraron productos" />
                                <Label style="-fx-font-family: 'Arial';                                             -fx-font-size: 11px;                                             -fx-text-fill: #C8D4C0;" text="Ajusta los filtros o añade un nuevo producto" />
                            </children>
                        </VBox>
                    </children>
                </StackPane>
            </placeholder>
        </TableView>

        <!--  SECCIÓN INFERIOR — Acciones               -->
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>

                <!-- Añadir Nuevo Producto -->
                <Button fx:id="btnAnadir" mnemonicParsing="false" prefHeight="38.0" styleClass="boton-accion-verde" text="＋  Añadir Nuevo Producto" />

                <!-- Editar Seleccionado -->
                <Button fx:id="btnEditar" mnemonicParsing="false" prefHeight="38.0" styleClass="boton-accion-oscuro" text="✎  Editar Seleccionado" />

                <!-- Spacer -->
                <Pane HBox.hgrow="ALWAYS" />

                <!-- Eliminar (separado a la derecha por precaución) -->
                <Button fx:id="btnEliminar" mnemonicParsing="false" prefHeight="38.0" styleClass="boton-accion-peligro" text="🗑  Eliminar" />

            </children>
        </HBox>

    </children>
</VBox>

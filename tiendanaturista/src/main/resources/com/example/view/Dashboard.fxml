<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.geometry.Insets?>

<BorderPane
    prefHeight="620.0"
    prefWidth="960.0"
    style="-fx-background-color: #FCFAF7;"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1">

    <!--  LEFT — Menú lateral                        -->
    <left>
        <VBox
            prefWidth="220.0"
            prefHeight="620.0"
            spacing="10.0"
            style="-fx-background-color: #FFFFFF;
                -fx-border-color: #E8E0D5;
                -fx-border-width: 0 1 0 0;">
            <padding>
                <Insets top="28.0" right="16.0" bottom="24.0" left="16.0" />
            </padding>
            <children>

                <!-- ── Logo / Marca ── -->
                <VBox alignment="CENTER" spacing="4.0">
                    <padding>
                        <Insets bottom="10.0" />
                    </padding>
                    <children>
                        <!-- Círculo decorativo con iniciales -->
                        <StackPane prefWidth="64.0" prefHeight="64.0">
                            <children>
                                <Circle radius="32.0"
                                        style="-fx-fill: #EAF4E6;
                                            -fx-stroke: #A8D5A2;
                                            -fx-stroke-width: 1.5;" />
                                <Label text="N&amp;B"
                                    style="-fx-font-family: 'Georgia';
                                            -fx-font-size: 16px;
                                            -fx-font-style: italic;
                                            -fx-text-fill: #3a7a2e;
                                            -fx-font-weight: bold;" />
                            </children>
                        </StackPane>

                        <!-- Nombre de la tienda -->
                        <Label text="Natural &amp; Belleza"
                            style="-fx-font-family: 'Georgia';
                                    -fx-font-size: 15px;
                                    -fx-font-style: italic;
                                    -fx-text-fill: #2d4a28;
                                    -fx-font-weight: normal;" />

                        <!-- Subtítulo -->
                        <Label text="Punto de Venta"
                            style="-fx-font-family: 'Arial';
                                    -fx-font-size: 9.5px;
                                    -fx-text-fill: #9ab890;
                                    -fx-letter-spacing: 2;" />
                    </children>
                </VBox>

                <!-- Separador decorativo -->
                <Separator style="-fx-background-color: #E0EDD9;" />

                <!-- Etiqueta de sección -->
                <Label text="MENÚ PRINCIPAL"
                    style="-fx-font-family: 'Arial';
                            -fx-font-size: 9px;
                            -fx-text-fill: #B0C4A8;
                            -fx-font-weight: bold;" >
                    <VBox.margin>
                        <Insets top="6.0" left="4.0" bottom="2.0" />
                    </VBox.margin>
                </Label>

                <!-- ── Botones de navegación ── -->
                <Button
                    text="🧾   Caja"
                    maxWidth="Infinity"
                    prefHeight="42.0"
                    styleClass="menu-button"
                    mnemonicParsing="false" />

                <Button
                    text="📦   Inventario"
                    maxWidth="Infinity"
                    prefHeight="42.0"
                    styleClass="menu-button"
                    mnemonicParsing="false" />

                <Button
                    text="📊   Reportes"
                    maxWidth="Infinity"
                    prefHeight="42.0"
                    styleClass="menu-button"
                    mnemonicParsing="false" />

                <!-- Spacer — empuja "Salir" al fondo -->
                <Pane VBox.vgrow="ALWAYS" />

                <!-- Separador antes de Salir -->
                <Separator style="-fx-background-color: #E0EDD9;" />

                <!-- Botón Salir -->
                <Button
                    text="🚪   Salir"
                    maxWidth="Infinity"
                    prefHeight="42.0"
                    styleClass="menu-button, menu-button-salir"
                    mnemonicParsing="false" />

            </children>
        </VBox>
    </left>


    <!--  TOP — Barra superior                       -->
    <top>
        <HBox
            prefHeight="52.0"
            alignment="CENTER_LEFT"
            spacing="12.0"
            style="-fx-background-color: #FFFFFF;
                -fx-border-color: #E8E0D5;
                -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets top="0" right="24.0" bottom="0" left="24.0" />
            </padding>
            <children>

                <!-- Título de vista activa -->
                <Label text="Dashboard"
                    style="-fx-font-family: 'Georgia';
                            -fx-font-size: 18px;
                            -fx-font-style: italic;
                            -fx-text-fill: #2d4a28;" />

                <!-- Spacer -->
                <Pane HBox.hgrow="ALWAYS" />

                <!-- Indicador de estado -->
                <HBox alignment="CENTER" spacing="6.0">
                    <children>
                        <Circle radius="5.0"
                                style="-fx-fill: #5da84b;" />
                        <Label text="Sistema activo"
                            style="-fx-font-family: 'Arial';
                                    -fx-font-size: 11px;
                                    -fx-text-fill: #7a9e6a;" />
                    </children>
                </HBox>

            </children>
        </HBox>
    </top>

    <!--  CENTER — Área de contenido dinámico        -->

    <center>
        <StackPane
            fx:id="contentArea"
            style="-fx-background-color: #FCFAF7;">

            <!-- Placeholder visible mientras no se carga ninguna vista -->
            <VBox alignment="CENTER" spacing="14.0">
                <children>
                    <StackPane prefWidth="80.0" prefHeight="80.0" VBox.vgrow="NEVER">
                        <children>
                            <Circle radius="40.0"
                                    style="-fx-fill: #EAF4E6;
                                        -fx-stroke: #C8E6C0;
                                        -fx-stroke-width: 1.5;" />
                            <Label text="🌿"
                                style="-fx-font-size: 30px;" />
                        </children>
                    </StackPane>

                    <Label text="Bienvenido al sistema"
                        style="-fx-font-family: 'Georgia';
                                -fx-font-size: 22px;
                                -fx-font-style: italic;
                                -fx-text-fill: #3a7a2e;" />

                    <Label text="Selecciona una opción del menú para comenzar"
                        style="-fx-font-family: 'Arial';
                                -fx-font-size: 12px;
                                -fx-text-fill: #A8B8A0;" />
                </children>
            </VBox>

        </StackPane>
    </center>


    <!--  BOTTOM — Barra de estado                   -->
    <bottom>
        <HBox
            prefHeight="28.0"
            alignment="CENTER_LEFT"
            spacing="16.0"
            style="-fx-background-color: #F0EBE1;
                -fx-border-color: #E0D8CE;
                -fx-border-width: 1 0 0 0;">
            <padding>
                <Insets top="0" right="20.0" bottom="0" left="20.0" />
            </padding>
            <children>
                <Label text="Natural &amp; Belleza  •  Productos Naturales"
                    style="-fx-font-family: 'Arial';
                            -fx-font-size: 10px;
                            -fx-text-fill: #B0A898;" />
                <Pane HBox.hgrow="ALWAYS" />
                <Label text="v1.0.0"
                    style="-fx-font-family: 'Arial';
                            -fx-font-size: 10px;
                            -fx-text-fill: #C8BFB4;" />
            </children>
        </HBox>
    </bottom>

</BorderPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="620.0" prefWidth="960.0" style="-fx-background-color: #FCFAF7;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">

    <!--  LEFT — Menu lateral   -->
    <left>
        <VBox prefHeight="620.0" prefWidth="220.0" spacing="10.0" style="-fx-background-color: #FFFFFF;                 
        -fx-border-color: #E8E0D5;                
        -fx-border-width: 0 1 0 0;">
            <padding>
                <Insets bottom="24.0" left="16.0" right="16.0" top="28.0" />
            </padding>
            <children>

                <!-- ── Logo / Marca ── -->
                <VBox alignment="CENTER" spacing="4.0">
                    <padding>
                        <Insets bottom="10.0" />
                    </padding>
                    <children>
                        <!-- Círculo decorativo con iniciales -->
                        <StackPane prefHeight="64.0" prefWidth="64.0">
                            <children>
                                <Circle radius="32.0" style="-fx-fill: #EAF4E6;                                             
                                -fx-stroke: #A8D5A2;                                             
                                -fx-stroke-width: 1.5;" />
                                <Label style="-fx-font-family: 'Georgia';                                             
                                -fx-font-size: 16px;                                            
                                -fx-font-style: italic;                                             
                                -fx-text-fill: #3a7a2e;                                             
                                -fx-font-weight: bold;" text="N&amp;B" />
                            </children>
                        </StackPane>

                        <!-- Nombre de la tienda -->
                        <Label style="-fx-font-family: 'Georgia';                                     
                        -fx-font-size: 15px;                                     
                        -fx-font-style: italic;                                     
                        -fx-text-fill: #2d4a28;                                     
                        -fx-font-weight: normal;" text="Natural &amp; Belleza" />

                        <!-- Subtítulo -->
                        <Label style="-fx-font-family: 'Arial';                                     
                        -fx-font-size: 9.5px;                                     
                        -fx-text-fill: #9ab890;                                    
                        -fx-letter-spacing: 2;" text="Punto de Venta" />
                    </children>
                </VBox>

                <!-- Separador decorativo -->
                <Separator style="-fx-background-color: #E0EDD9;" />

                <!-- ── Botones de navegación ── -->
                <Button maxWidth="Infinity" mnemonicParsing="false" prefHeight="42.0" style="
                -fx-background-color: #3a7a2e; 
                -fx-text-fill: #f0f7ee;" styleClass="menu-button" text="💲   Caja" />

                <Button maxWidth="Infinity" mnemonicParsing="false" prefHeight="42.0" style="
                -fx-background-color: #3a7a2e; 
                -fx-text-fill: #f0f7ee;" styleClass="menu-button" text="📦   Inventario" />

                <Button maxWidth="Infinity" mnemonicParsing="false" prefHeight="42.0" style="
                -fx-background-color: #3a7a2e; 
                -fx-text-fill: #f0f7ee;" styleClass="menu-button" text="📊   Reportes" />

                <!-- Spacer — empuja "Salir" al fondo -->
                <Pane VBox.vgrow="ALWAYS" />

                <!-- Separador antes de Salir -->
                <Separator style="-fx-background-color: #E0EDD9;" />

                <!-- Botón Salir -->
                <Button maxWidth="Infinity" mnemonicParsing="false" prefHeight="42.0" style="
                -fx-background-color: #3a7a2e; 
                -fx-text-fill: #f0f7ee;" styleClass="menu-button, menu-button-salir" text="🚪   Salir" />

            </children>
        </VBox>
    </left>


    <!--  TOP — Barra superior       -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="52.0" spacing="12.0" style="-fx-background-color: #FFFFFF;                 
        -fx-border-color: #E8E0D5;                 
        -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets bottom="0" left="24.0" right="24.0" top="0" />
            </padding>
            <children>

                <!-- Título de vista activa -->
                <Label style="-fx-font-family: 'Georgia';                             
                -fx-font-size: 18px;                             
                -fx-font-style: italic;                            
                -fx-text-fill: #2d4a28;" text="MENÚ PRINCIPAL" />

                <!-- Spacer -->
                <Pane HBox.hgrow="ALWAYS" />

                <!-- Indicador de estado -->
                <HBox alignment="CENTER" spacing="6.0">
                    <children>
                        <Circle radius="5.0" style="-fx-fill: #5da84b;" />
                        <Label style="-fx-font-family: 'Arial';                                     
                        -fx-font-size: 11px;                                     
                        -fx-text-fill: #7a9e6a;" text="Sistema activo" />
                    </children>
                </HBox>

            </children>
        </HBox>
    </top>

    <!--  CENTER — Área de contenido dinámico        -->

    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #FCFAF7;">

            <!-- Placeholder visible mientras no se carga ninguna vista -->
            <VBox alignment="CENTER" spacing="14.0">
                <children>
                    <StackPane prefHeight="80.0" prefWidth="80.0" VBox.vgrow="NEVER">
                        <children>
                            <Circle radius="40.0" style="-fx-fill: #EAF4E6;                                         
                            -fx-stroke: #C8E6C0;                                         
                            -fx-stroke-width: 1.5;" />
                            <Label style="-fx-font-size: 30px;" text="🌿" />
                        </children>
                    </StackPane>

                    <Label style="-fx-font-family: 'Georgia';                                
                    -fx-font-size: 22px;                                 
                    -fx-font-style: italic;                                 
                    -fx-text-fill: #3a7a2e;" text="Bienvenido al sistema" />

                    <Label style="-fx-font-family: 'Arial';                                 
                    -fx-font-size: 12px;                                 
                    -fx-text-fill: #A8B8A0;" text="Selecciona una opción del menú para comenzar" />
                </children>
            </VBox>

        </StackPane>
    </center>


    <!--  BOTTOM — Barra de estado                   -->
    <bottom>
        <HBox alignment="CENTER_LEFT" prefHeight="28.0" spacing="16.0" style="-fx-background-color: #F0EBE1;                 
        -fx-border-color: #E0D8CE;                 
        -fx-border-width: 1 0 0 0;">
            <padding>
                <Insets bottom="0" left="20.0" right="20.0" top="0" />
            </padding>
            <children>
                <Label style="-fx-font-family: 'Arial';                             
                -fx-font-size: 10px;                             
                -fx-text-fill: #B0A898;" text="Natural &amp; Belleza  •  Productos Naturales" />
                <Pane HBox.hgrow="ALWAYS" />
                <Label style="-fx-font-family: 'Arial';                             
                -fx-font-size: 10px;                             
                -fx-text-fill: #C8BFB4;" text="v1.0.0" />
            </children>
        </HBox>
    </bottom>

</BorderPane>
